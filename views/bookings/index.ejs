<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-8 offset-2">
    <h3>My Bookings 🏨</h3>
    <hr/>

    <% if(bookings.length === 0) { %>
      <div class="alert alert-info">
        Abhi koi booking nahi hai! 
        <a href="/listings">Listings dekho</a>
      </div>
    <% } %>

    <% for(let booking of bookings) { %>
    <% if(booking.listing) { %>
    <div class="card mb-3" style="border-radius: 1rem; overflow: hidden;">
      <div class="row g-0">
        <div class="col-md-3">
          <img 
            src="<%= booking.listing.image?.url %>" 
            class="img-fluid" 
            style="height: 150px; object-fit: cover;"
          />
        </div>
        <div class="col-md-9">
          <div class="card-body">
            <h5><%= booking.listing.title %></h5>
            <p class="text-muted mb-1">
              📍 <%= booking.listing.location %>, <%= booking.listing.country %>
            </p>
            <p class="mb-1">
              📅 <b>Check-in:</b> <%= booking.checkIn.toDateString() %>
            </p>
            <p class="mb-1">
              📅 <b>Check-out:</b> <%= booking.checkOut.toDateString() %>
            </p>
            <p class="mb-1">
              🌙 <b><%= booking.nights %> Nights</b> — 
              &#8377; <b><%= booking.totalPrice.toLocaleString("en-IN") %></b>
            </p>
            <form 
              method="POST" 
              action="/bookings/<%= booking._id %>?_method=DELETE">
              <button class="btn btn-sm btn-outline-danger mt-2">
                ❌ Cancel Booking
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
    <% } %>
    <% } %>
  </div>
</div>